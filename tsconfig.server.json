{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.js"]
}
